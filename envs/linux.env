export foundry_LICENSE=4101@10.66.9.43
export ADSKFLEX_LICENSE_FILE=2080@10.66.9.43

export KATANA_ROOT=/urja-mc-02/render/apps/lin/Katana/Katana8.0v4
export KTOA_ROOT=/urja-mc-02/render/apps/lin/Katana/ktoa/ktoa-4.4.3.1-kat8.0-linux
export KATANAUSD_ROOT=/usr/local/plugins/Resources/Usd

export DEFAULT_RENDERER=arnold
export KATANA_TAGLINE="With KtoA 4.4.3.1 and Arnold 7.4.3.1"
